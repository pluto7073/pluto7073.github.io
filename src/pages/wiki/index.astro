---
import Head from "../../components/Head.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Wiki from "../../components/Wiki.astro";
import {getCollection, type InferEntrySchema, type RenderedContent} from "astro:content";
import { count } from "../../components/SidebarContents.astro";

export async function getMods() {
    const docs = await getCollection('docs');
    let docsMap = new Map<string, {id: string, body?: string, collection: "docs", data: InferEntrySchema<"docs">, rendered?: RenderedContent, filePath?: string}>();
    for (let x of docs) {
        docsMap.set(x.id, x);
    }
    return docsMap;
}

const mods = (await getCollection('docs')).filter((doc) => doc.id.startsWith("wiki/") && doc.data.dir && count("/", doc.id) === 1).map(doc => {
    doc.id = doc.id.replace("wiki/", "");
    return doc;
});
---

<html lang="en">
<head>
    <Head title="Wiki"/>
</head>
<body class="font-sans m-0 p-0 text-left min-h-screen text-gray-200 text-base leading-relaxed overflow-x-hidden relative"
      style="background: linear-gradient(135deg, #000000 0%, #51317e 100%) fixed;">
<Header/>

<main transition:animate="slide" class="w-full max-w-6xl mx-auto px-4 py-8 relative z-2 min-h-[calc(100vh-120px)]">

    <!--h1 class="text-5xl font-extrabold mb-4 text-[#9082CE]"> Sorry! This Page is Under Construction! </h1-->

    <section class="page-header text-center py-16 mb-12 glow-inner rounded-3xl">
        <div class="w-full shrink-0 items-center text-center"><h1 class="text-5xl font-extrabold mb-4 text-[#9082CE]"> Mod Wikis </h1> </div>
        <div class="w-48 h-1 mx-auto rounded-full separator transition-all"></div>
    </section>

    <section class="mods-grid">
        <div id="posts-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                mods.map(doc => (
                    <Wiki id={doc.id} banner={doc.data.picture} name={doc.data.mod} desc={doc.data.desc} />
                ))
            }
        </div>
    </section>
</main>

<Footer/>

</body>
</html>